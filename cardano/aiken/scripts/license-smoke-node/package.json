{
  "name": "nuauth-license-smoke",
  "private": true,
  "type": "module",
  "description": "Plutus V3 license listing smoke (Lucid Evolution; Deno 0.10.x cannot attach V3 spend scripts).",
  "scripts": {
    "postinstall": "node -e \"const fs=require('fs'),p=require('path');const src=p.join('node_modules','libsodium-wrappers-sumo','node_modules','libsodium-sumo','dist','modules-sumo-esm','libsodium-sumo.mjs');const dst=p.join('node_modules','libsodium-wrappers-sumo','dist','modules-sumo-esm','libsodium-sumo.mjs');if(fs.existsSync(src)){fs.mkdirSync(p.dirname(dst),{recursive:true});fs.copyFileSync(src,dst);}\"",
    "smoke:emulator": "node license-smoke.mjs",
    "smoke:preprod": "CARDANO_BACKEND=blockfrost node license-smoke.mjs"
  },
  "dependencies": {
    "@lucid-evolution/lucid": "^0.4.29",
    "libsodium-sumo": "^0.7.15"
  }
}
